---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found — BMGR">
  <section class="min-h-[65vh] flex items-center justify-center bg-parchment">
    <div class="text-center px-6">
      <p class="font-display text-[10rem] md:text-[14rem] leading-none font-bold text-ink/5 select-none">404</p>
      <p class="font-display text-xl text-ink-soft -mt-8 mb-2">This page doesn't exist</p>
      <p class="text-sm text-ink-muted mb-8" style="font-family: 'Tiro Devanagari Hindi', serif;">यो पृष्ठ भेटिएन</p>
      <a href="/" class="px-6 py-3 bg-vermillion text-white text-sm font-semibold uppercase tracking-wide rounded-sm hover:bg-vermillion-dark transition-colors">
        Back Home
      </a>
    </div>
  </section>
</BaseLayout>

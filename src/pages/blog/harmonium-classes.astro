---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'Join Our Weekly Harmonium Classes';
const date = '2026-02-20';
const author = 'BMGR Team';
---

<BaseLayout title={`${title} — BMGR Blog`}>
  <article class="py-16 md:py-24 bg-parchment">
    <div class="max-w-2xl mx-auto px-6">
      <a href="/blog/" class="inline-flex items-center gap-1 text-xs text-vermillion font-semibold uppercase tracking-wider hover:underline mb-8">&larr; All posts</a>

      <header class="mb-10">
        <div class="flex items-center gap-3 text-xs text-ink-muted mb-3">
          <time datetime={date}>February 20, 2026</time>
          <span class="w-1 h-1 rounded-full bg-ink-faint"></span>
          <span>{author}</span>
        </div>
        <h1 class="font-display text-3xl md:text-4xl font-bold">{title}</h1>
      </header>

      <div class="dhaka-border mb-10" aria-hidden="true"></div>

      <div class="space-y-5 text-ink-soft leading-relaxed">
        <p>
          One of BMGR's most beloved programs is our <strong>weekly harmonium class</strong>, held at the BCGR Community Hall. With 4-5 regular participants, the class has been running successfully and continues to grow.
        </p>
        <p>
          The harmonium is central to Bhutanese Nepali music — from devotional bhajans to folk songs. Our classes are designed for all skill levels, whether you've never touched a harmonium or you've been playing for years. Led by experienced musicians within BMGR, the sessions are supportive, informal, and focused on learning together.
        </p>
        <p>
          We also encourage members to send their children. Building musical skills in the next generation is one of BMGR's core goals, and the harmonium is a wonderful place to start.
        </p>
        <p>
          Classes are free for BMGR members. Interested? <a href="/contact/" class="text-indigo hover:underline">Contact us</a> to learn more and join.
        </p>
      </div>

      <div class="dhaka-border my-10" aria-hidden="true"></div>

      <!-- Comments -->
      <section>
        <h3 class="font-display text-xl font-bold mb-6">Comments</h3>
        <form id="comment-form" class="mb-8 bg-parchment-warm border border-ink-faint/10 rounded-sm p-5">
          <div class="grid sm:grid-cols-2 gap-3 mb-3">
            <div>
              <label for="c-name" class="block text-xs font-semibold text-ink-muted uppercase tracking-wider mb-1">Name</label>
              <input type="text" id="c-name" required class="w-full px-3 py-2 bg-parchment border border-ink-faint/15 rounded-sm text-sm focus:border-indigo focus:ring-1 focus:ring-indigo transition" />
            </div>
            <div>
              <label for="c-email" class="block text-xs font-semibold text-ink-muted uppercase tracking-wider mb-1">Email (not published)</label>
              <input type="email" id="c-email" required class="w-full px-3 py-2 bg-parchment border border-ink-faint/15 rounded-sm text-sm focus:border-indigo focus:ring-1 focus:ring-indigo transition" />
            </div>
          </div>
          <div class="mb-3">
            <label for="c-text" class="block text-xs font-semibold text-ink-muted uppercase tracking-wider mb-1">Comment</label>
            <textarea id="c-text" rows="3" required class="w-full px-3 py-2 bg-parchment border border-ink-faint/15 rounded-sm text-sm focus:border-indigo focus:ring-1 focus:ring-indigo transition resize-none"></textarea>
          </div>
          <button type="submit" class="px-5 py-2 bg-vermillion text-white text-xs font-bold uppercase tracking-wider rounded-sm hover:bg-vermillion-dark transition cursor-pointer">Post Comment</button>
        </form>
        <div id="comments-list" class="space-y-4"></div>
        <p id="no-comments" class="text-sm text-ink-muted italic">No comments yet. Be the first to share your thoughts!</p>
      </section>
    </div>
  </article>
</BaseLayout>

<script>
  function initComments() {
    const KEY = 'bmgr-comments-harmonium-classes';
    const form = document.getElementById('comment-form') as HTMLFormElement;
    const list = document.getElementById('comments-list');
    const none = document.getElementById('no-comments');
    function load() { try { return JSON.parse(localStorage.getItem(KEY)||'[]'); } catch { return []; } }
    function render() {
      const c = load();
      if (!list) return;
      if (!c.length) { list.innerHTML = ''; none?.classList.remove('hidden'); return; }
      none?.classList.add('hidden');
      list.innerHTML = c.map((x:any) => `<div class="p-4 bg-parchment-warm border border-ink-faint/10 rounded-sm"><div class="flex items-center gap-2 mb-2"><div class="w-7 h-7 rounded-full bg-vermillion/15 flex items-center justify-center text-xs font-bold text-vermillion">${x.name[0].toUpperCase()}</div><span class="text-sm font-semibold">${x.name}</span><span class="text-[10px] text-ink-faint ml-auto">${x.date}</span></div><p class="text-sm text-ink-soft">${x.text}</p></div>`).join('');
    }
    form?.addEventListener('submit',(e)=>{e.preventDefault();const n=(document.getElementById('c-name')as HTMLInputElement).value.trim();const t=(document.getElementById('c-text')as HTMLTextAreaElement).value.trim();const c=load();c.push({name:n,text:t,date:new Date().toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})});localStorage.setItem(KEY,JSON.stringify(c));form.reset();render();});
    render();
  }
  initComments();
  document.addEventListener('astro:after-swap', initComments);
</script>

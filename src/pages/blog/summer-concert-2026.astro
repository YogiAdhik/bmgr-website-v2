---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'The Grand Summer Concert Is Coming';
const date = '2026-03-10';
const author = 'Yogesh Adhikari';
const slug = 'summer-concert-2026';
---

<BaseLayout title={`${title} — BMGR Blog`}>
  <article class="py-16 md:py-24 bg-parchment">
    <div class="max-w-2xl mx-auto px-6">
      <a href="/blog/" class="inline-flex items-center gap-1 text-xs text-vermillion font-semibold uppercase tracking-wider hover:underline mb-8">&larr; All posts</a>

      <header class="mb-10">
        <div class="flex items-center gap-3 text-xs text-ink-muted mb-3">
          <time datetime={date}>March 10, 2026</time>
          <span class="w-1 h-1 rounded-full bg-ink-faint"></span>
          <span>{author}</span>
        </div>
        <h1 class="font-display text-3xl md:text-4xl font-bold">{title}</h1>
      </header>

      <div class="rounded-sm overflow-hidden mb-10">
        <img src="/images/Concert2.jpg" alt="BMGR concert performance" class="w-full" loading="lazy" />
      </div>

      <div class="dhaka-border mb-10" aria-hidden="true"></div>

      <div class="space-y-5 text-ink-soft leading-relaxed">
        <p>
          We've been talking about this for months, and it's finally taking shape: BMGR is organizing a <strong>Grand Community Musical Event</strong> scheduled for <strong>June 2026</strong>. This will be the biggest program we've ever put together.
        </p>
        <p>
          The vision came out of our February meeting, where the group sat down and laid out what we wanted this event to be. Not just a concert — a full cultural experience. Here's what's in the works:
        </p>
        <ul class="list-disc list-inside space-y-2 pl-2">
          <li><strong>Nepali and folk songs</strong> that every generation knows — the kind that get everyone singing along</li>
          <li><strong>Cultural dances</strong> choreographed by community dance teachers including Manita, Amashi, and Laxuman</li>
          <li><strong>A Nepali drama</strong> directed by Kiran Pele dai, drawing from his experience in over 100 stage productions</li>
          <li><strong>A volunteer appreciation ceremony</strong> — recognizing the people who make BMGR and our community run</li>
          <li><strong>Honorable guests</strong> from the broader Bhutanese Nepali community</li>
        </ul>
        <p>
          We're debating whether to invite a well-known Nepali artist as a guest performer or to keep the focus entirely on local Bhutanese talent. Personally, I lean toward showcasing our own — we have incredible musicians right here in Rochester who don't get enough of a stage. But we're still discussing it.
        </p>
        <p>
          Logistics are being handled collectively. Birkha dai is coordinating the program structure, Tek dai is managing the budget, and I'm helping with promotion and the technical setup. We have the sound equipment — 4 powered speakers, 2 subwoofers, wireless mics, the whole rig — so we can make it sound professional.
        </p>
        <p>
          The event will likely be held at a community venue in the Rochester area. We're looking at spaces that can hold 200+ people comfortably.
        </p>
        <p>
          If you want to help — whether as a performer, volunteer, or sponsor — we'd love to hear from you. This event is for the community, and the more people involved, the better it'll be. Reach out through our <a href="/contact/" class="text-indigo hover:underline">contact page</a>.
        </p>
        <p>
          More details coming soon. Stay tuned.
        </p>
        <p class="text-sm text-ink-muted">— Yogesh Adhikari</p>
      </div>

      <div class="dhaka-border my-10" aria-hidden="true"></div>

      <section>
        <h3 class="font-display text-xl font-bold mb-6">Comments</h3>
        <form id="comment-form" class="mb-8 bg-parchment-warm border border-ink-faint/10 rounded-sm p-5">
          <div class="grid sm:grid-cols-2 gap-3 mb-3">
            <div><label for="c-name" class="block text-xs font-semibold text-ink-muted uppercase tracking-wider mb-1">Name</label><input type="text" id="c-name" required class="w-full px-3 py-2 bg-parchment border border-ink-faint/15 rounded-sm text-sm focus:border-indigo focus:ring-1 focus:ring-indigo transition" /></div>
            <div><label for="c-email" class="block text-xs font-semibold text-ink-muted uppercase tracking-wider mb-1">Email (not published)</label><input type="email" id="c-email" required class="w-full px-3 py-2 bg-parchment border border-ink-faint/15 rounded-sm text-sm focus:border-indigo focus:ring-1 focus:ring-indigo transition" /></div>
          </div>
          <div class="mb-3"><label for="c-text" class="block text-xs font-semibold text-ink-muted uppercase tracking-wider mb-1">Comment</label><textarea id="c-text" rows="3" required class="w-full px-3 py-2 bg-parchment border border-ink-faint/15 rounded-sm text-sm focus:border-indigo focus:ring-1 focus:ring-indigo transition resize-none"></textarea></div>
          <button type="submit" class="px-5 py-2 bg-vermillion text-white text-xs font-bold uppercase tracking-wider rounded-sm hover:bg-vermillion-dark transition cursor-pointer">Post Comment</button>
        </form>
        <div id="comments-list" class="space-y-4"></div>
        <p id="no-comments" class="text-sm text-ink-muted italic">No comments yet. Be the first to share your thoughts!</p>
      </section>
    </div>
  </article>
</BaseLayout>

<script define:vars={{ slug }}>
  function initComments() {
    const KEY = 'bmgr-comments-' + slug; const form = document.getElementById('comment-form'); const list = document.getElementById('comments-list'); const none = document.getElementById('no-comments');
    function load() { try { return JSON.parse(localStorage.getItem(KEY)||'[]'); } catch { return []; } }
    function render() { const c = load(); if (!list) return; if (!c.length) { list.innerHTML=''; none?.classList.remove('hidden'); return; } none?.classList.add('hidden'); list.innerHTML = c.map((x)=>`<div class="p-4 bg-parchment-warm border border-ink-faint/10 rounded-sm"><div class="flex items-center gap-2 mb-2"><div class="w-7 h-7 rounded-full bg-vermillion/15 flex items-center justify-center text-xs font-bold text-vermillion">${x.name[0].toUpperCase()}</div><span class="text-sm font-semibold">${x.name}</span><span class="text-[10px] text-ink-faint ml-auto">${x.date}</span></div><p class="text-sm text-ink-soft">${x.text}</p></div>`).join(''); }
    form?.addEventListener('submit',(e)=>{e.preventDefault();const n=document.getElementById('c-name').value.trim();const t=document.getElementById('c-text').value.trim();const c=load();c.push({name:n,text:t,date:new Date().toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})});localStorage.setItem(KEY,JSON.stringify(c));form.reset();render();});
    render();
  }
  initComments(); document.addEventListener('astro:after-swap', initComments);
</script>

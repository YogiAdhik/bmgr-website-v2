---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'Welcome to BMGR';
const date = '2026-03-15';
const author = 'BMGR Team';
---

<BaseLayout title={`${title} — BMGR Blog`}>
  <article class="py-16 md:py-24 bg-parchment">
    <div class="max-w-2xl mx-auto px-6">
      <!-- Back link -->
      <a href="/blog/" class="inline-flex items-center gap-1 text-xs text-vermillion font-semibold uppercase tracking-wider hover:underline mb-8">
        &larr; All posts
      </a>

      <!-- Header -->
      <header class="mb-10">
        <div class="flex items-center gap-3 text-xs text-ink-muted mb-3">
          <time datetime={date}>March 15, 2026</time>
          <span class="w-1 h-1 rounded-full bg-ink-faint"></span>
          <span>{author}</span>
        </div>
        <h1 class="font-display text-3xl md:text-4xl font-bold">{title}</h1>
      </header>

      <div class="dhaka-border mb-10" aria-hidden="true"></div>

      <!-- Content -->
      <div class="prose-custom space-y-5 text-ink-soft leading-relaxed">
        <p>
          We are excited to launch the official website of the <strong>Bhutanese Musical Group of Rochester (BMGR)</strong>. This website is a milestone in our journey to preserve and promote Bhutanese Nepali music, arts, and culture right here in Rochester, New York.
        </p>
        <p>
          BMGR was founded in 2019 by a group of passionate musicians who carried their love for music from Bhutan and Nepal to the United States. Our roots go back even further — to the Flamingo Band, co-founded in 1993 in Timai, Jhapa, Nepal, by our President Birkha Gurung and percussionist Lalit Gurung.
        </p>
        <p>
          Today, BMGR is home to over 13 members — vocalists, percussionists, composers, songwriters, and community leaders. Together, we organize harmonium classes, Bhajan Sandhya (devotional evenings), cultural performances at Dashain, Tihar, and other celebrations, and community concerts that bring generations together.
        </p>
        <p>
          Through this website, you can learn about our members, keep up with upcoming events, explore our gallery, and reach out to get involved. We welcome musicians and music lovers of all skill levels.
        </p>
        <p>
          Thank you for visiting. We look forward to sharing our music and culture with you.
        </p>
        <p class="text-sm italic text-ink-muted">
          — The BMGR Team
        </p>
      </div>

      <div class="dhaka-border my-10" aria-hidden="true"></div>

      <!-- Newsletter -->
      <div class="bg-parchment-warm border border-ink-faint/10 rounded-sm p-5 mb-12">
        <h3 class="font-display text-sm font-semibold mb-1">Get updates from BMGR</h3>
        <p class="text-xs text-ink-muted mb-3">Event reminders and news delivered to your inbox.</p>
        <form id="post-newsletter" class="flex gap-2">
          <input type="email" required placeholder="your@email.com"
            class="flex-1 px-3 py-2 bg-parchment border border-ink-faint/15 rounded-sm text-sm focus:border-indigo focus:ring-1 focus:ring-indigo transition" />
          <button type="submit" class="px-4 py-2 bg-forest text-white text-xs font-bold uppercase tracking-wider rounded-sm hover:bg-forest/90 transition cursor-pointer">
            Subscribe
          </button>
        </form>
      </div>

      <!-- Comments Section -->
      <section id="comments-section">
        <h3 class="font-display text-xl font-bold mb-6">Comments</h3>

        <!-- Comment form -->
        <form id="comment-form" class="mb-8 bg-parchment-warm border border-ink-faint/10 rounded-sm p-5">
          <div class="grid sm:grid-cols-2 gap-3 mb-3">
            <div>
              <label for="c-name" class="block text-xs font-semibold text-ink-muted uppercase tracking-wider mb-1">Name</label>
              <input type="text" id="c-name" required
                class="w-full px-3 py-2 bg-parchment border border-ink-faint/15 rounded-sm text-sm focus:border-indigo focus:ring-1 focus:ring-indigo transition" />
            </div>
            <div>
              <label for="c-email" class="block text-xs font-semibold text-ink-muted uppercase tracking-wider mb-1">Email (not published)</label>
              <input type="email" id="c-email" required
                class="w-full px-3 py-2 bg-parchment border border-ink-faint/15 rounded-sm text-sm focus:border-indigo focus:ring-1 focus:ring-indigo transition" />
            </div>
          </div>
          <div class="mb-3">
            <label for="c-text" class="block text-xs font-semibold text-ink-muted uppercase tracking-wider mb-1">Comment</label>
            <textarea id="c-text" rows="3" required
              class="w-full px-3 py-2 bg-parchment border border-ink-faint/15 rounded-sm text-sm focus:border-indigo focus:ring-1 focus:ring-indigo transition resize-none"></textarea>
          </div>
          <button type="submit" class="px-5 py-2 bg-vermillion text-white text-xs font-bold uppercase tracking-wider rounded-sm hover:bg-vermillion-dark transition cursor-pointer">
            Post Comment
          </button>
        </form>

        <!-- Comments list (client-side, persisted in localStorage) -->
        <div id="comments-list" class="space-y-4"></div>
        <p id="no-comments" class="text-sm text-ink-muted italic">No comments yet. Be the first to share your thoughts!</p>
      </section>
    </div>
  </article>
</BaseLayout>

<script>
  function initComments() {
    const STORAGE_KEY = 'bmgr-comments-welcome-to-bmgr';
    const form = document.getElementById('comment-form') as HTMLFormElement;
    const list = document.getElementById('comments-list');
    const noComments = document.getElementById('no-comments');

    function loadComments(): Array<{ name: string; text: string; date: string }> {
      try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); }
      catch { return []; }
    }

    function renderComments() {
      const comments = loadComments();
      if (!list) return;
      if (comments.length === 0) {
        list.innerHTML = '';
        noComments?.classList.remove('hidden');
        return;
      }
      noComments?.classList.add('hidden');
      list.innerHTML = comments.map((c) => `
        <div class="p-4 bg-parchment-warm border border-ink-faint/10 rounded-sm">
          <div class="flex items-center gap-2 mb-2">
            <div class="w-7 h-7 rounded-full bg-vermillion/15 flex items-center justify-center text-xs font-bold text-vermillion">${c.name.charAt(0).toUpperCase()}</div>
            <span class="text-sm font-semibold">${c.name}</span>
            <span class="text-[10px] text-ink-faint ml-auto">${c.date}</span>
          </div>
          <p class="text-sm text-ink-soft">${c.text}</p>
        </div>
      `).join('');
    }

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const nameEl = document.getElementById('c-name') as HTMLInputElement;
      const textEl = document.getElementById('c-text') as HTMLTextAreaElement;
      const comments = loadComments();
      comments.push({
        name: nameEl.value.trim(),
        text: textEl.value.trim(),
        date: new Date().toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }),
      });
      localStorage.setItem(STORAGE_KEY, JSON.stringify(comments));
      form.reset();
      renderComments();
    });

    renderComments();

    // Newsletter
    const nlForm = document.getElementById('post-newsletter') as HTMLFormElement | null;
    nlForm?.addEventListener('submit', (ev) => {
      ev.preventDefault();
      const btn = nlForm.querySelector('button') as HTMLButtonElement;
      const input = nlForm.querySelector('input') as HTMLInputElement;
      if (btn) { const o = btn.textContent; btn.textContent = 'Subscribed!'; btn.disabled = true; input.value = ''; setTimeout(() => { btn.textContent = o; btn.disabled = false; }, 3000); }
    });
  }
  initComments();
  document.addEventListener('astro:after-swap', initComments);
</script>

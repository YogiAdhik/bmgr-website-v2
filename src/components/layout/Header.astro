---
import { siteConfig } from '@/config/site.config';

const currentPath = Astro.url.pathname;
---

<header id="site-header" class="sticky top-0 z-50 bg-parchment/90 backdrop-blur-md border-b border-ink-faint/15 transition-shadow duration-300">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group">
      <img src={siteConfig.logo.src} alt="" class="w-9 h-9 rounded-full" width="36" height="36" />
      <div class="leading-none">
        <span class="font-display text-lg font-semibold tracking-wide text-ink">BMGR</span>
        <span class="hidden sm:block text-[10px] text-ink-muted tracking-[0.15em] uppercase">Rochester, NY</span>
      </div>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-1" aria-label="Main">
      {siteConfig.nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            'px-3 py-2 text-[13px] font-semibold tracking-[0.08em] uppercase transition-colors',
            currentPath === item.href
              ? 'text-vermillion'
              : 'text-ink-muted hover:text-ink',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Mobile toggle -->
    <button id="menu-btn" class="md:hidden w-10 h-10 flex flex-col items-center justify-center gap-1.5 cursor-pointer" aria-label="Menu" aria-expanded="false">
      <span class="menu-line w-5 h-[1.5px] bg-ink transition-all"></span>
      <span class="menu-line w-5 h-[1.5px] bg-ink transition-all"></span>
      <span class="menu-line w-3.5 h-[1.5px] bg-ink transition-all ml-auto"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-nav" class="md:hidden overflow-hidden max-h-0 transition-all duration-300 bg-parchment border-t border-ink-faint/10">
    <nav class="flex flex-col px-6 py-4 gap-1">
      {siteConfig.nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            'py-2.5 text-sm font-semibold tracking-wide uppercase border-b border-ink-faint/8 last:border-0 transition-colors',
            currentPath === item.href ? 'text-vermillion' : 'text-ink-soft hover:text-vermillion',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<style>
  #site-header.has-shadow {
    box-shadow: 0 1px 8px rgba(26, 20, 16, 0.06);
  }
  #menu-btn[aria-expanded='true'] .menu-line:nth-child(1) { transform: rotate(45deg) translate(3px, 3px); }
  #menu-btn[aria-expanded='true'] .menu-line:nth-child(2) { opacity: 0; }
  #menu-btn[aria-expanded='true'] .menu-line:nth-child(3) { width: 1.25rem; transform: rotate(-45deg) translate(3px, -3px); }
</style>

<script>
  function initNav() {
    const btn = document.getElementById('menu-btn');
    const nav = document.getElementById('mobile-nav');
    const header = document.getElementById('site-header');

    btn?.addEventListener('click', () => {
      const open = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!open));
      if (nav) nav.style.maxHeight = open ? '0' : nav.scrollHeight + 'px';
    });

    nav?.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => {
        btn?.setAttribute('aria-expanded', 'false');
        if (nav) nav.style.maxHeight = '0';
      })
    );

    window.addEventListener('scroll', () => {
      header?.classList.toggle('has-shadow', scrollY > 10);
    }, { passive: true });
  }
  initNav();
  document.addEventListener('astro:after-swap', initNav);
</script>
